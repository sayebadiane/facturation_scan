<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         FORMULAIRE FACTURE CLIENT — champs supplémentaires Axis
    ══════════════════════════════════════════════════════════════════════════ -->
    <record id="view_move_form_axis_facturation" model="ir.ui.view">
        <field name="name">account.move.form.axis.facturation</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Référence client après le champ ref existant -->
            <xpath expr="//field[@name='ref']" position="after">
                <field name="x_reference_client" placeholder="Référence commande client"/>
            </xpath>

            <!-- Commercial après partner_id -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="x_commercial_id" options="{'no_create': True}"/>
            </xpath>

            <!-- Onglet supplémentaire : Informations Axis -->
            <xpath expr="//page[@name='invoice_tab']" position="after">
                <page name="axis_info" string="Infos Axis">
                    <group>
                        <group string="Suivi commercial">
                            <field name="x_reference_client"/>
                            <field name="x_commercial_id" options="{'no_create': True}"/>
                            <field name="x_delai_paiement"/>
                        </group>
                        <group string="Relance">
                            <field name="x_statut_relance" widget="statusbar"
                                   statusbar_visible="non_relance,relance_1,relance_2,relance_3,contentieux"/>
                            <field name="x_date_echeance_relance"/>
                            <field name="x_montant_regle"/>
                            <field name="x_montant_restant"/>
                        </group>
                    </group>
                    <group string="Avoir" invisible="move_type not in ('out_refund', 'in_refund')">
                        <field name="x_motif_avoir"/>
                    </group>
                    <group string="Note interne">
                        <field name="x_note_interne" nolabel="1" placeholder="Note visible en interne uniquement…"/>
                    </group>
                </page>
            </xpath>

            <!-- Boutons d'action relance dans la barre de boutons -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_marquer_relance"
                        type="object"
                        string="Relancer"
                        icon="fa-bell"
                        class="oe_stat_button"
                        invisible="move_type != 'out_invoice' or payment_state == 'paid'"/>
            </xpath>

        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         LISTE FACTURES CLIENT — colonnes supplémentaires
    ══════════════════════════════════════════════════════════════════════════ -->
    <record id="view_out_invoice_tree_axis" model="ir.ui.view">
        <field name="name">account.move.list.axis.facturation</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="x_reference_client" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='amount_residual_signed']" position="before">
                <field name="x_commercial_id" optional="show"/>
                <field name="x_statut_relance" optional="show" widget="badge"
                       decoration-success="x_statut_relance == 'non_relance'"
                       decoration-warning="x_statut_relance in ['relance_1', 'relance_2']"
                       decoration-danger="x_statut_relance in ['relance_3', 'contentieux']"/>
            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         ACTION — Tableau de bord facturation Axis
    ══════════════════════════════════════════════════════════════════════════ -->
    <record id="action_axis_factures_client" model="ir.actions.act_window">
        <field name="name">Factures clients</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="domain">[('move_type', '=', 'out_invoice')]</field>
        <field name="context">{'default_move_type': 'out_invoice'}</field>
    </record>

    <record id="action_axis_avoirs_client" model="ir.actions.act_window">
        <field name="name">Avoirs clients</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('move_type', '=', 'out_refund')]</field>
        <field name="context">{'default_move_type': 'out_refund'}</field>
    </record>

    <record id="action_axis_factures_relance" model="ir.actions.act_window">
        <field name="name">Factures à relancer</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('move_type', '=', 'out_invoice'),
            ('payment_state', 'not in', ['paid', 'in_payment']),
            ('state', '=', 'posted')
        ]</field>
        <field name="context">{'default_move_type': 'out_invoice'}</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         FILTRES ET REGROUPEMENTS SUPPLÉMENTAIRES
    ══════════════════════════════════════════════════════════════════════════ -->
    <record id="view_account_move_filter_axis" model="ir.ui.view">
        <field name="name">account.move.search.axis</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='status']" position="after">
                <separator/>
                <filter string="À relancer" name="a_relancer"
                        domain="[('x_statut_relance', '!=', 'non_relance')]"/>
                <filter string="Contentieux" name="contentieux"
                        domain="[('x_statut_relance', '=', 'contentieux')]"/>
            </xpath>
            <xpath expr="//group" position="inside">
                <filter string="Commercial" name="group_commercial"
                        context="{'group_by': 'x_commercial_id'}"/>
                <filter string="Statut relance" name="group_relance"
                        context="{'group_by': 'x_statut_relance'}"/>
            </xpath>
        </field>
    </record>

</odoo>
